# ============================================================
# Agent Factory — Environment Variables
# ============================================================
# Copie este arquivo para .env e preencha suas chaves.
# O .env esta no .gitignore — suas chaves NEVER sao commitadas.
# ============================================================

# === PROVEDORES SEM CARTAO DE CREDITO ===

# Groq (recomendado) — 30 RPM, Llama 4, Qwen3
# https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — 1.500 req/dia, 1M tokens contexto
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cerebras — 1M tokens/dia, inferencia mais rapida
# https://inference.cerebras.ai/
CEREBRAS_API_KEY=

# Mistral — 1B tokens/mes (Experiment plan)
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# HuggingFace — 300 req/hora, serverless
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# === PROVEDORES COM CARTAO / VERIFICACAO ===

# DeepSeek — modelo mais forte (V3)
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenRouter — gateway 20+ modelos free
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# MIMO (Xiaomi) — MiMo-V2.5-Pro, 1T params, competitivo com Claude
# https://platform.xiaomimimo.com/
MIMO_API_KEY=

# NVIDIA NIM — GPU cloud, phone verification
# https://build.nvidia.com/
NVIDIA_API_KEY=

# Cloudflare Workers AI — edge computing
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# === PROJETO SOLAR (solarman-solar-monitor) ===

# SOLARMAN API
SOLARMAN_APIID=
SOLARMAN_APKKEY=
SOLARMAN_EMAIL=
SOLARMAN_PASSWORD=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=solarman
DB_USER=postgres
DB_PASSWORD=

# Notificacoes
NTFY_TOPIC=
